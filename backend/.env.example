# =============================================================================
# PROCUREMENT SYSTEM — Variabili d'ambiente
# Copia questo file in .env e compila i valori prima di avviare l'applicazione.
# Genera chiavi sicure con: python -c "import secrets; print(secrets.token_urlsafe(32))"
# =============================================================================

# === SICUREZZA (OBBLIGATORIO in produzione) ===
SECRET_KEY=generate-with-python-secrets-token-urlsafe-32
JWT_SECRET_KEY=generate-with-python-secrets-token-urlsafe-32

# === APP ===
APP_NAME=Procurement System
APP_VERSION=1.0.0
DEBUG=false
ENVIRONMENT=production
APP_BASE_URL=https://your-frontend.railway.app
ALLOWED_ORIGINS=["https://your-frontend.railway.app"]

# JWT token durata
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# === DATABASE ===
DATABASE_URL=postgresql://user:password@localhost:5432/procurement

# === SMTP (per notifiche email) ===
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@domain.com
SMTP_PASSWORD=your-app-password
SMTP_TLS=true
EMAIL_FROM=procurement@azienda.it
EMAIL_ALBO_FORNITORI=albo@azienda.it

# === ALYANTE (integrazione ERP) ===
ALYANTE_ENABLED=false
ALYANTE_API_URL=https://alyante-api.azienda.it
ALYANTE_API_KEY=your-api-key

# === NON CONFORMITA' WEBHOOK ===
NC_API_KEY=your-nc-api-key

# === ANTHROPIC (AI analisi contratti) ===
ANTHROPIC_API_KEY=sk-ant-...

# === UPLOAD ===
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=50

# === RATE LIMITING ===
RATE_LIMIT_PER_MINUTE=60
