# ============================================================
# PROCUREMENT SYSTEM - Environment Configuration
# Copiare in .env e compilare PRIMA del deploy
# ============================================================

# Database
DB_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# JWT (generare con: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=CHANGE_ME_JWT_SECRET
SECRET_KEY=CHANGE_ME_APP_SECRET

# Email SMTP
SMTP_HOST=smtp.yourprovider.com
SMTP_PORT=587
SMTP_USER=noreply@telethon.it
SMTP_PASSWORD=CHANGE_ME_SMTP_PASSWORD
EMAIL_FROM=noreply@telethon.it
EMAIL_ALBO_FORNITORI=albofornitori@telethon.it

# App port
PORT=80

# CORS (origins separate da virgola in JSON array)
# ALLOWED_ORIGINS=["https://procurement.telethon.it"]

# AI Contract Analysis (Anthropic Claude)
# Ottieni la chiave su https://console.anthropic.com
# Lascia vuoto per disabilitare la funzione AI
ANTHROPIC_API_KEY=

# Webhook security keys (opzionali)
# ALYANTE_API_KEY=CHANGE_ME_ALYANTE_KEY
# NC_API_KEY=CHANGE_ME_NC_KEY
